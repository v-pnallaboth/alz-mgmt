{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "parLocations": {
      "value": [
        "eastus2",
        "westus2",
        "centralus"
      ]
    },
    "parTags": {
      "value": {}
    },
    "parEnableTelemetry": {
      "value": true
    },
    "parGlobalResourceLock": {
      "value": {
        "name": "GlobalResourceLock",
        "kind": "None",
        "notes": "This lock was created by the ALZ Bicep Accelerator."
      }
    },
    "parVirtualWanResourceGroupNamePrefix": {
      "value": "rg-alz-amer-conn"
    },
    "parDnsResourceGroupNamePrefix": {
      "value": "rg-alz-dns"
    },
    "parDnsPrivateResolverResourceGroupNamePrefix": {
      "value": "rg-alz-dnspr"
    },
    "vwan": {
      "value": {
        "name": "vwan-alz-eastus2",
        "location": "eastus2",
        "type": "Standard",
        "allowBranchToBranchTraffic": true,
        "lock": {
          "kind": "None",
          "name": "vwan-lock",
          "notes": "This lock was created by the ALZ Bicep Hub Networking Module."
        }
      }
    },
    "vwanHubs": {
      "value": [
        {
          "hubName": "vhub-alz-eastus2",
          "location": "eastus2",
          "addressPrefix": "10.0.0.0/22",
          "allowBranchToBranchTraffic": true,
          "preferredRoutingGateway": "VpnGateway",
          "azureFirewallSettings": {
            "deployAzureFirewall": false,
            "name": "afw-alz-eastus2"
          },
          "expressRouteGatewaySettings": {
            "deployExpressRouteGateway": false,
            "name": "ergw-alz-eastus2",
            "minScaleUnits": 1,
            "maxScaleUnits": 1,
            "allowNonVirtualWanTraffic": false
          },
          "s2sVpnGatewaySettings": {
            "deployS2sVpnGateway": true,
            "name": "s2s-alz-eastus2",
            "scaleUnit": 1
          },
          "p2sVpnGatewaySettings": {
            "deployP2sVpnGateway": false,
            "name": "p2s-alz-eastus2",
            "scaleUnit": 1,
            "vpnServerConfiguration": {
              "vpnAuthenticationTypes": [
                "AAD"
              ]
            },
            "vpnClientAddressPool": {
              "addressPrefixes": [
                "172.16.0.0/24"
              ]
            }
          },
          "ddosProtectionPlanSettings": {
            "deployDdosProtectionPlan": false,
            "name": "ddos-alz-eastus2",
            "tags": {}
          },
          "dnsSettings": {
            "deployPrivateDnsZones": true,
            "deployDnsPrivateResolver": false,
            "privateDnsResolverName": "dnspr-alz-eastus2"
          },
          "bastionSettings": {
            "deployBastion": true,
            "name": "bas-alz-eastus2",
            "sku": "Standard"
          },
          "sideCarVirtualNetwork": {
            "name": "vnet-sidecar-alz-eastus2",
            "sidecarVirtualNetworkEnabled": true,
            "addressPrefixes": [
              "10.0.4.0/22"
            ]
          }
        },
        {
          "hubName": "vhub-alz-westus2",
          "location": "westus2",
          "addressPrefix": "10.1.0.0/22",
          "allowBranchToBranchTraffic": true,
          "preferredRoutingGateway": "VpnGateway",
          "azureFirewallSettings": {
            "deployAzureFirewall": false,
            "name": "afw-alz-westus2"
          },
          "expressRouteGatewaySettings": {
            "deployExpressRouteGateway": false,
            "name": "ergw-alz-westus2",
            "minScaleUnits": 1,
            "maxScaleUnits": 1,
            "allowNonVirtualWanTraffic": false
          },
          "s2sVpnGatewaySettings": {
            "deployS2sVpnGateway": true,
            "name": "s2s-alz-westus2",
            "scaleUnit": 1
          },
          "p2sVpnGatewaySettings": {
            "deployP2sVpnGateway": false,
            "name": "p2s-alz-westus2",
            "scaleUnit": 1,
            "vpnServerConfiguration": {
              "vpnAuthenticationTypes": [
                "AAD"
              ]
            },
            "vpnClientAddressPool": {
              "addressPrefixes": [
                "172.16.1.0/24"
              ]
            }
          },
          "ddosProtectionPlanSettings": {
            "deployDdosProtectionPlan": false
          },
          "dnsSettings": {
            "deployPrivateDnsZones": true,
            "deployDnsPrivateResolver": false,
            "privateDnsResolverName": "dnspr-alz-westus2",
            "privateDnsZones": [
              "privatelink.{regionName}.azurecontainerapps.io",
              "privatelink.{regionName}.kusto.windows.net",
              "privatelink.{regionName}.azmk8s.io",
              "privatelink.{regionName}.prometheus.monitor.azure.com",
              "privatelink.{regionCode}.backup.windowsazure.com"
            ]
          },
          "bastionSettings": {
            "deployBastion": false,
            "name": "bas-alz-westus2",
            "sku": "Standard"
          },
          "sideCarVirtualNetwork": {
            "name": "vnet-sidecar-alz-westus2",
            "sidecarVirtualNetworkEnabled": true,
            "addressPrefixes": [
              "10.1.4.0/22"
            ]
          }
        },
        {
          "hubName": "vhub-alz-centralus",
          "location": "centralus",
          "addressPrefix": "10.2.0.0/22",
          "allowBranchToBranchTraffic": true,
          "preferredRoutingGateway": "VpnGateway",
          "azureFirewallSettings": {
            "deployAzureFirewall": false,
            "name": "afw-alz-centralus"
          },
          "expressRouteGatewaySettings": {
            "deployExpressRouteGateway": false,
            "name": "ergw-alz-centralus",
            "minScaleUnits": 1,
            "maxScaleUnits": 1,
            "allowNonVirtualWanTraffic": false
          },
          "s2sVpnGatewaySettings": {
            "deployS2sVpnGateway": true,
            "name": "s2s-alz-centralus",
            "scaleUnit": 1
          },
          "p2sVpnGatewaySettings": {
            "deployP2sVpnGateway": false,
            "name": "p2s-alz-centralus",
            "scaleUnit": 1,
            "vpnServerConfiguration": {
              "vpnAuthenticationTypes": [
                "AAD"
              ]
            },
            "vpnClientAddressPool": {
              "addressPrefixes": [
                "172.16.2.0/24"
              ]
            }
          },
          "ddosProtectionPlanSettings": {
            "deployDdosProtectionPlan": false
          },
          "dnsSettings": {
            "deployPrivateDnsZones": true,
            "deployDnsPrivateResolver": false,
            "privateDnsResolverName": "dnspr-alz-centralus",
            "privateDnsZones": [
              "privatelink.{regionName}.azurecontainerapps.io",
              "privatelink.{regionName}.kusto.windows.net",
              "privatelink.{regionName}.azmk8s.io",
              "privatelink.{regionName}.prometheus.monitor.azure.com",
              "privatelink.{regionCode}.backup.windowsazure.com"
            ]
          },
          "bastionSettings": {
            "deployBastion": false,
            "name": "bas-alz-centralus",
            "sku": "Standard"
          },
          "sideCarVirtualNetwork": {
            "name": "vnet-sidecar-alz-centralus",
            "sidecarVirtualNetworkEnabled": true,
            "addressPrefixes": [
              "10.2.4.0/22"
            ]
          }
        }
      ]
    }
  }
}